{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Bun CLI (Effect subpaths)",
  "extends": "./base.json",
  "compilerOptions": {
    "types": ["bun-types"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowJs": true,
    "noEmit": false
  }
}
