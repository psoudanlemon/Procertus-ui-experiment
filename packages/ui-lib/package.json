{
  "name": "@procertus-ui/ui-lib",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./design-tokens-showcase": "./src/components/design-tokens-showcase/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "lint": "oxlint src .storybook",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "storybook": "env NODE_OPTIONS=\"--require ../../scripts/storybook-network-fallback.cjs\" storybook dev -p 6007 --host localhost --disable-telemetry",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@procertus-ui/ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",

    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.1.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/react-vite": "^10.3.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.0",
    "@workspace/typescript-config": "workspace:*",
    "bun-types": "^1.3.11",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "storybook": "^10.3.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
