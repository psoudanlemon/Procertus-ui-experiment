{
  "name": "@procertus-ui/ui-certification",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "storybook": "env NODE_OPTIONS=\"--require ../../scripts/storybook-network-fallback.cjs\" storybook dev -p 6008 --host localhost --disable-telemetry",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@procertus-ui/domain-certification": "workspace:*",
    "@procertus-ui/ui": "workspace:*",
    "@procertus-ui/ui-lib": "workspace:*",
    "@procertus-ui/ui-pt1-prototype": "workspace:*",
    "lucide-react": "^0.486.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/react-vite": "^10.3.0",
    "@tailwindcss/vite": "^4.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@workspace/typescript-config": "workspace:*",
    "bun-types": "^1.3.13",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "storybook": "^10.3.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
